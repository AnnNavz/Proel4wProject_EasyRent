@model ForgotPasswordViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Forgot Password";
}

<div class="mb-4">
    <h2 class="fw-bold h3 mb-1">Reset Password</h2>
    <p class="text-muted">Enter your email address and we'll send you instructions to reset your password.</p>
</div>

<form asp-action="ForgotPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <div class="mb-4">
        <label asp-for="Email" class="form-label small fw-semibold text-secondary"></label>
        <div class="input-group">
            <input asp-for="Email" class="form-control" placeholder="name@company.com" required />
        </div>
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn btn-primary shadow-sm mb-3">
        Send Reset Link <i class="bi bi-envelope-at ms-2"></i>
    </button>

    <div class="text-center mt-3">
        <p class="small text-muted">
            Remember your password?
            <a asp-action="LoginView" class="text-primary text-decoration-none fw-bold ms-1">Back to Sign In</a>
        </p>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}