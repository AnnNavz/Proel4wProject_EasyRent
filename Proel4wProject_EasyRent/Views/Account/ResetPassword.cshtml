@model ResetPasswordViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Reset Password";
}

<div class="mb-4">
    <h2 class="fw-bold h3 mb-1">Set New Password</h2>
    <p class="text-muted">Ensure your new password is secure and at least 12 characters long.</p>
</div>

<form asp-action="ResetPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    @* Hidden fields to persist the reset context *@
    <input type="hidden" asp-for="Email" />
    <input type="hidden" asp-for="Token" />

    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label small fw-semibold text-secondary">New Password</label>
        <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••" required />
        <span asp-validation-for="NewPassword" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="form-label small fw-semibold text-secondary">Confirm New Password</label>
        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" required />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn btn-primary shadow-sm mb-3">
        Update Password <i class="bi bi-check-circle ms-2"></i>
    </button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}