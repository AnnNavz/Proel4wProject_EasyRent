@model LoginViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Login";
}

<div class="mb-4">
    <h2 class="fw-bold h3 mb-1">Sign In</h2>
    <p class="text-muted">Enter your credentials to access your account.</p>
</div>

<form asp-action="Login" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label small fw-semibold text-secondary"></label>
        <div class="input-group">
            <input asp-for="Email" class="form-control" placeholder="name@company.com" required />
        </div>
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <label asp-for="Password" class="form-label small fw-semibold text-secondary mb-0"></label>
            <a href="#" class="text-primary text-decoration-none small fw-medium">Forgot password?</a>
        </div>
        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" required />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="mb-4 d-flex align-items-center">
        <div class="form-check">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label small text-muted">Keep me signed in</label>
        </div>
    </div>

    <button type="submit" class="btn btn-primary shadow-sm mb-3">
        Sign In <i class="bi bi-box-arrow-in-right ms-2"></i>
    </button>

    <div class="text-center mt-3">
        <p class="small text-muted">
            Don't have an account?
            <a asp-controller="Register" asp-action="Register" class="text-primary text-decoration-none fw-bold ms-1">Create an account</a>
        </p>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}