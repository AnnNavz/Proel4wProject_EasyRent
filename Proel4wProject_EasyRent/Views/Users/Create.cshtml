@model Proel4wProject_EasyRent.Models.Users

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add New User";
}

<div class="container-fluid">
    @* Consistent Back Link *@
    <div class="mb-3">
        <a asp-action="Index" class="text-decoration-none text-muted small d-inline-flex align-items-center">
            <i class="bi bi-arrow-left me-2"></i> Back to User List
        </a>
    </div>

    @* Changed to col-lg-11 to be WIDER than the vehicle's col-lg-9 *@
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="management-card p-5 shadow-sm border-0 bg-white" style="border-radius: 16px;">

                <div class="mb-5">
                    <h2 class="fw-bold mb-0" style="font-family: Montserrat; color: #20515d;">Register User</h2>
                    <p class="text-muted">Enter the details of the new user for the EasyRent system.</p>
                </div>

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    @* Name Row *@
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="UserFirstName" class="form-label fw-bold small text-muted text-uppercase">First Name</label>
                            <input asp-for="UserFirstName" class="form-control" placeholder="e.g. Juan" />
                            <span asp-validation-for="UserFirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UserLastName" class="form-label fw-bold small text-muted text-uppercase">Last Name</label>
                            <input asp-for="UserLastName" class="form-control" placeholder="e.g. Dela Cruz" />
                            <span asp-validation-for="UserLastName" class="text-danger small"></span>
                        </div>
                    </div>

                    @* Email *@
                    <div class="mb-4">
                        <label asp-for="UserEmail" class="form-label fw-bold small text-muted text-uppercase">Email Address</label>
                        <input asp-for="UserEmail" class="form-control" placeholder="email@easyrent.com" />
                        <span asp-validation-for="UserEmail" class="text-danger small"></span>
                    </div>

                    <hr class="my-5 opacity-25">

                    @* Security Row *@
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-bold small text-muted text-uppercase">Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold small text-muted text-uppercase">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    @* Role Selection *@
                    <div class="mb-5">
                        <label asp-for="RoleId" class="form-label fw-bold small text-muted text-uppercase">System Role</label>
                        <select asp-for="RoleId" class="form-select" asp-items="ViewBag.UserRole">
                            <option value="">-- Select Access Level --</option>
                        </select>
                        <span asp-validation-for="RoleId" class="text-danger small"></span>
                    </div>

                    @* Action Buttons (Styled like Vehicle Create) *@
                    <div class="mt-5 d-flex gap-2">
                        <button type="submit" class="btn btn-teal px-5 py-2" style="background-color: #20515d; color: white; border: none; border-radius: 8px; font-weight: 600;">
                            <i class="bi bi-person-plus-fill me-2"></i> Create User
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}