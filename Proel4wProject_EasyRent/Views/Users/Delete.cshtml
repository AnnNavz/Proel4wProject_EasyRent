@model Proel4wProject_EasyRent.Models.Users

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Delete User";
}

<div class="container-fluid">
    <div class="mb-3">
        <a asp-action="Index" class="text-decoration-none text-muted small d-inline-flex align-items-center">
            <i class="bi bi-arrow-left me-2"></i> Cancel and Go Back
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="management-card p-4 shadow-sm border-0 bg-white text-center" style="border-radius: 16px; border-top: 5px solid #dc3545 !important;">
                <div class="mb-3">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                </div>

                <h2 class="fw-bold" style="font-family: Montserrat;">Delete Account?</h2>
                <p class="text-muted">You are about to permanently remove <strong>@Model.UserFirstName @Model.UserLastName</strong>. This action cannot be undone.</p>

                <div class="bg-light p-3 rounded-3 mb-4 text-start">
                    <div class="small text-muted mb-1 text-uppercase fw-bold">User Information</div>
                    <div class="text-dark">@Model.UserEmail</div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="UserId" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger py-2 fw-bold">
                            <i class="bi bi-trash3 me-2"></i> Permanently Delete
                        </button>
                        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none">Keep this account</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>