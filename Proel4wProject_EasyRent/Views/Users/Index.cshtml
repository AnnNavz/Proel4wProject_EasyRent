@model IEnumerable<Proel4wProject_EasyRent.Models.Users>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 fw-bold" style="font-family: Montserrat;">User Management</h1>
        <p class="text-muted">Review and manage all registered EasyRent accounts.</p>
    </div>
    <a asp-action="Create" class="btn btn-teal">
        <i class="bi bi-person-plus-fill me-2"></i> Add New User
    </a>
</div>

<div class="management-card">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr class="text-muted small">
                    <th>USER DETAILS</th>
                    <th>EMAIL ADDRESS</th>
                    <th>ROLE</th>
                    <th class="text-end">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="user-avatar me-3">
                                    @item.UserFirstName.Substring(0, 1)@item.UserLastName.Substring(0, 1)
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">@item.UserFirstName @item.UserLastName</div>
                                    <div class="small text-muted">ID: #@item.UserId</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted">@item.UserEmail</td>
                        <td>
                            <span class="badge rounded-pill @(item.RoleId == 1 ? "bg-primary" : "bg-secondary") bg-opacity-10 text-@(item.RoleId == 1 ? "primary" : "secondary") px-3 py-2">
                                @(item.RoleId == 1 ? "Admin" : "Customer")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.UserId" class="action-link text-primary bg-primary bg-opacity-10 me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.UserId" class="action-link text-info bg-info bg-opacity-10 me-2">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.UserId" class="action-link text-danger bg-danger bg-opacity-10">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>