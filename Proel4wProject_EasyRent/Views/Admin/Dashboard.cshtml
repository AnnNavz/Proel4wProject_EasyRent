@using Proel4wProject_EasyRent.Models
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";

    var recentUsers = ViewBag.RecentUsers as List<Users> ?? new List<Users>();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <span class="badge bg-opacity-10 text-teal px-3 py-2 mb-2"
                  style="background-color: rgba(32, 81, 93, 0.1); color: var(--easyrent-teal);">
                System Overview
            </span>
            <h2 class="display-6">Admin Dashboard</h2>
        </div>
        <a asp-controller="Vehicles" asp-action="Create" class="btn btn-teal shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Add New Vehicle
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="admin-card p-4 text-center">
                <p class="text-muted small fw-bold mb-1">TOTAL USERS</p>
                <h3 class="mb-0">@ViewBag.TotalUsers</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card p-4 text-center">
                <p class="text-muted small fw-bold mb-1">ACTIVE RENTALS</p>
                <h3 class="mb-0 text-success">@ViewBag.ActiveRentals</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card p-4 text-center">
                <p class="text-muted small fw-bold mb-1">FLEET STATUS</p>
                <h3 class="mb-0">@ViewBag.FleetPercentage%</h3>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-8">
            <div class="admin-card p-4">
                <h4 class="mb-4">Recent User Activity</h4>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (recentUsers.Any())
                            {
                                foreach (var user in recentUsers)
                                {
                                    <tr>
                                        <td class="fw-semibold">@user.UserFirstName @user.UserLastName</td>
                                        <td class="text-muted">@user.UserEmail</td>
                                        <td>
                                            <span class="badge @(user.RoleId == 1 ? "bg-primary" : "bg-success") rounded-pill">
                                                @(user.RoleId == 1 ? "Admin" : "Customer")
                                            </span>
                                        </td>
                                        <td>
                                            <a asp-controller="Users" asp-action="Details" asp-route-id="@user.UserId"
                                               class="btn btn-sm btn-outline-secondary">View</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No users found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-card p-4 bg-teal text-white" style="background-color: var(--easyrent-teal);">
                <h4 class="mb-3">Quick Actions</h4>
                <div class="d-grid gap-2">
                    <a asp-controller="Users" asp-action="Index" class="btn btn-light text-start py-3">
                        <i class="bi bi-person-gear me-2"></i> Manage User Roles
                    </a>
                    <a asp-controller="Vehicles" asp-action="Index" class="btn btn-light text-start py-3">
                        <i class="bi bi-car-front me-2"></i> Update Vehicle Prices
                    </a>
                    <a asp-controller="Admin" asp-action="Reservations" class="btn btn-light text-start py-3">
                        <i class="bi bi-calendar-check me-2"></i> View All Bookings
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>