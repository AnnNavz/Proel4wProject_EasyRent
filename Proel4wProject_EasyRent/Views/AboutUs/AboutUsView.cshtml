@{
    ViewData["Title"] = "About Us";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    :root {
        --easyrent-teal: #225761;
        --easyrent-teal-light: #eef4f5;
        --easyrent-dark: #1a444d;
        --heading-font: 'Montserrat', sans-serif;
        --body-font: 'Inter', sans-serif;
    }

    body {
        font-family: var(--body-font);
        background-color: #ffffff;
        color: #333;
    }

    /* --- Hero Section with Parallax Effect --- */
    .hero-wrap {
        height: 500px;
        position: relative;
        background: linear-gradient(rgba(34, 87, 97, 0.6), rgba(26, 68, 77, 0.9)), url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=1920');
        background-attachment: fixed;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
        clip-path: polygon(0 0, 100% 0, 100% 90%, 0% 100%);
    }

    .hero-content h1 {
        font-family: var(--heading-font);
        font-weight: 800;
        font-size: 4rem;
        letter-spacing: -2px;
        margin-bottom: 1rem;
    }

    /* --- Stats Section --- */
    .stats-bar {
        margin-top: -50px;
        position: relative;
        z-index: 10;
    }

    .stat-card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        text-align: center;
        border-bottom: 4px solid var(--easyrent-teal);
    }

    /* --- Team Section --- */
    .section-label {
        font-family: var(--heading-font);
        color: var(--easyrent-teal);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 2px;
        font-weight: 700;
    }

    .team-card-enhanced {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        background: #fff;
        border: 1px solid #f0f0f0;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

        .team-card-enhanced:hover {
            transform: translateY(-15px);
            box-shadow: 0 20px 40px rgba(34, 87, 97, 0.15);
        }

    .img-hover-zoom {
        height: 320px;
        overflow: hidden;
    }

        .img-hover-zoom img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .5s ease;
        }

    .team-card-enhanced:hover .img-hover-zoom img {
        transform: scale(1.1);
    }

    .social-links-overlay {
        position: absolute;
        top: 20px;
        right: -50px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: right 0.4s ease;
    }

    .team-card-enhanced:hover .social-links-overlay {
        right: 20px;
    }

    .social-icon {
        width: 35px;
        height: 35px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--easyrent-teal);
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .role-tag {
        font-size: 0.7rem;
        background: var(--easyrent-teal-light);
        color: var(--easyrent-teal);
        padding: 4px 12px;
        border-radius: 50px;
        display: inline-block;
        margin-bottom: 10px;
        font-weight: 600;
    }

    /* --- CTA Section --- */
    .cta-banner {
        background: var(--easyrent-teal);
        border-radius: 20px;
        padding: 60px;
        color: white;
        margin-top: 80px;
        position: relative;
        overflow: hidden;
    }

        .cta-banner::after {
            content: '🚗';
            position: absolute;
            font-size: 15rem;
            bottom: -50px;
            right: -30px;
            opacity: 0.1;
            transform: rotate(-15deg);
        }
</style>

<div class="hero-wrap">
    <div class="hero-content container">
        <h1 class="animate__animated animate__fadeInDown">Driven by Passion.</h1>
        <p class="lead text-white-50">Redefining vehicle rentals in Talisay City through innovation and ease.</p>
    </div>
</div>

<div class="container stats-bar">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="stat-card">
                <h2 class="fw-bold mb-0" style="color: var(--easyrent-teal)">#1</h2>
                <p class="text-muted small text-uppercase mb-0">Rated in Cebu</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <h2 class="fw-bold mb-0" style="color: var(--easyrent-teal)">24/7</h2>
                <p class="text-muted small text-uppercase mb-0">Smart Support</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <h2 class="fw-bold mb-0" style="color: var(--easyrent-teal)">5-Star</h2>
                <p class="text-muted small text-uppercase mb-0">Vehicle Fleet</p>
            </div>
        </div>
    </div>
</div>

<div class="container py-5 mt-5">
    <div class="row align-items-center mb-5 pb-5">
        <div class="col-lg-6">
            <span class="section-label">Our Story</span>
            <h2 class="display-6 fw-bold mb-4" style="font-family: var(--heading-font);">Why We Built EasyRent</h2>
            <p class="text-muted">
                What started as a capstone project for the Asian College of Technology evolved into a mission to bridge the gap between vehicle owners and travelers. We believe renting a car should be as simple as a few clicks.
            </p>
            <ul class="list-unstyled mt-4">
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> User-Centric UI/UX Design</li>
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Secure REST API Integration</li>
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Real-time Fleet Management</li>
            </ul>
        </div>
        <div class="col-lg-6">
            <img src="~/images/bgH.png" class="img-fluid rounded-4 shadow-lg" alt="Team Work">
        </div>
    </div>

    <div class="text-center mb-5">
        <span class="section-label">The Minds Behind EasyRent</span>
        <h2 class="fw-bold" style="font-family: var(--heading-font);">Meet Our Developers</h2>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-lg-3 col-md-6">
            <div class="team-card-enhanced">
                <div class="img-hover-zoom">
                    <img src="~/images/1.png" alt="Ann Shirley">
                </div>
                <div class="social-links-overlay">
                    <a href="#" class="social-icon"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-github"></i></a>
                </div>
                <div class="p-4">
                    <span class="role-tag">Programmer</span>
                    <h5 class="fw-bold mb-1">Ann Shirley Navasca</h5>
                    <p class="text-muted small">Ensuring quality and reliability in every line of code.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="team-card-enhanced">
                <div class="img-hover-zoom">
                    <img src="~/images/2.png" alt="Marven James">
                </div>
                <div class="social-links-overlay">
                    <a href="#" class="social-icon"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-github"></i></a>
                </div>
                <div class="p-4">
                    <span class="role-tag">Database Manager</span>
                    <h5 class="fw-bold mb-1">Marven James Bas</h5>
                    <p class="text-muted small">Building secure, high-performance database systems.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="team-card-enhanced">
                <div class="img-hover-zoom">
                    <img src="~/images/4h.png" alt="Developer">
                </div>
                <div class="social-links-overlay">
                    <a href="#" class="social-icon"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-github"></i></a>
                </div>
                <div class="p-4">
                    <span class="role-tag">UI Designer</span>
                    <h5 class="fw-bold mb-1">Karmelie Ann Canasa</h5>
                    <p class="text-muted small">Bridging the gap between aesthetics and functionality.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="team-card-enhanced">
                <div class="img-hover-zoom">
                    <img src="~/images/5h.png" alt="Developer">
                </div>
                <div class="social-links-overlay">
                    <a href="#" class="social-icon"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-github"></i></a>
                </div>
                <div class="p-4">
                    <span class="role-tag">System Analyst</span>
                    <h5 class="fw-bold mb-1">Rheaniel Abad</h5>
                    <p class="text-muted small">Expert in system logic and workflow optimization.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="cta-banner shadow-lg text-center text-lg-start">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h2 class="fw-bold display-6">Start your journey today.</h2>
                <p class="lead mb-0">Experience the difference with Cebu's most trusted rental fleet.</p>
            </div>
            <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                <a href="/Vehicles" class="btn btn-light btn-lg px-5 py-3 fw-bold" style="color: var(--easyrent-teal); border-radius: 12px;">Browse Vehicles</a>
            </div>
        </div>
    </div>
</div>