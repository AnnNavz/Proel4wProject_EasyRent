@{
    ViewData["Title"] = "Terms of Service";
}

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="fw-bold mb-4" style="color: #20515d;">Terms of Service</h1>
            <p class="lead text-muted mb-5">Effective Date: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

            <div class="content text-secondary" style="line-height: 1.8;">
                <h4 class="fw-bold text-dark mt-4 mb-3">1. Agreement to Terms</h4>
                <p>By accessing or using the EasyRent platform, you agree to be bound by these Terms of Service. If you disagree with any part of the terms, you may not access our services.</p>

                <h4 class="fw-bold text-dark mt-5 mb-3">2. Rental Policies</h4>
                <p>EasyRent pairs users directly with premium vehicles. All terms regarding booking cancellations, non-refundable deposits, and driver-assisted experiences must be strictly followed according to the listing criteria.</p>

                <h4 class="fw-bold text-dark mt-5 mb-3">3. User Responsibilities</h4>
                <p>As a renter, you are responsible for maintaining accurate profile information and adhering to the safety standards outlined. Sharing false identity documents is prohibited.</p>

            </div>
        </div>
    </div>
</div>
