                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="benefit-card">
                        <div class="icon-box"><i class="bi bi-buildings"></i></div>
                        <h4>Great for Groups</h4>
                        <p class="desc-text">Spacious vans for your all travel needs.</p>
                        <ul class="benefit-list">
                            <li>Comfort and Space</li>
                            <li>Group Travel</li>
                            <li>Family Outings</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>


<!--Call to Action section-->
<div id="cta-section-wrapper" style="width: 100%; overflow: hidden;">
    <section class="start-journey-cta">
        <div class="bg-circle circle-left"></div>
        <div class="bg-circle circle-right"></div>

        <img src="~/images/van-small.png" class="vehicle-actor van-left" alt="Van">
        <img src="~/images/suv-small.png" class="vehicle-actor suv-right" alt="SUV">

        <div class="cta-content">
            <span style="text-transform: uppercase; letter-spacing: 3px; font-weight: 600; font-size: 0.9rem; display: block; margin-bottom: 10px;">EasyRent</span>
            <h1>Start Your Journey Now</h1>
            <p>Experience seamless rentals with zero hidden fees. Select your vehicle now and enjoy the ultimate driving experience.</p>
            <button class="btn-book">Book Now</button>
        </div>
    </section>
</div>