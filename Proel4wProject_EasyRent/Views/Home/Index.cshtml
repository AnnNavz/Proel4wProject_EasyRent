                        <div class="col-lg-3 col-md-12">
                            <button class="btn btn-search">Search Vehicle</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </div>

   
  <!--Vehicle Categories section-->
<div id="easyrent-homepage">
    <section class="vehicle-section">
        <div class="container text-center">
            <div class="section-header mb-5">
                <div class="category-badge mx-auto">
                    <i class="bi bi-truck"></i> Vehicle Categories
                </div>
                <h2>Find Your Perfect Vehicle Types</h2>
                <p class="text-muted small mx-auto" style="max-width: 650px;">
                    Choose from our premium SUVs and spacious vans to find the perfect fit for your next trip.
                    Discover a reliable fleet designed to handle any journey or occasion with ease.
                </p>
            </div>

            <div class="row g-4 text-start d-flex align-items-stretch">
                <div class="col-lg-6">
                    <div class="vehicle-card">
                        <div class="image-wrapper">
                            <img src="/images/suv-preview.png" class="main-vehicle-img" alt="SUV">
                            <button class="wish-btn"><i class="bi bi-star"></i></button>
                            <div class="price-tag-badge">
                                <span>Starting From</span>
                                <b>₱5,000 per 3 hours</b>
                            </div>
                        </div>
                        <div class="card-info">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <h5 class="v-name mb-0">Sport Utility Vehicle (SUV)</h5>
                                <span class="avail-label">+4 available</span>
                            </div>
                            <p class="text-primary small mb-3" style="color: #468585 !important;">Driver-assisted experience</p>
                            <p class="text-secondary small mb-4">Conquer any road with our premium SUVs, built for power, comfort, and ultimate versatility.</p>

                            <div class="fw-bold small mb-2">Benefits:</div>
                            <div class="feature-grid">
                                <div class="feature-item">Fully Air-Conditioned</div>
                                <div class="feature-item">Ample Luggage Space</div>
                                <div class="feature-item">7 seats capacity</div>
                                <div class="feature-item">Advanced Safety</div>
                                <div class="feature-item">Gasoline given</div>
                            </div>

                            <button class="btn-action">Browse More <i class="bi bi-arrow-right"></i></button>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="vehicle-card">
                        <div class="image-wrapper">
                            <img src="/images/van-preview.png" class="main-vehicle-img" alt="VAN">
                            <button class="wish-btn"><i class="bi bi-star"></i></button>
                            <div class="price-tag-badge">
                                <span>Starting From</span>
                                <b>₱5,000 per 3 hours</b>
                            </div>
                        </div>
                        <div class="card-info">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <h5 class="v-name mb-0">Mitsubishi VAN</h5>
                                <span class="avail-label">+3 available</span>
                            </div>
                            <p class="text-primary small mb-3" style="color: #468585 !important;">Driver-assisted experience</p>
                            <p class="text-secondary small mb-4">A spacious and reliable option for group travels, ensuring everyone rides in comfort and style.</p>

                            <div class="fw-bold small mb-2">Benefits:</div>
                            <div class="feature-grid">
                                <div class="feature-item">Dual Air-Conditioning</div>
                                <div class="feature-item">Extra Large Cargo Space</div>
                                <div class="feature-item">8 to 18 seats capacity</div>
                                <div class="feature-item">Advanced Safety</div>
                                <div class="feature-item">Gasoline given</div>
                            </div>

                            <button class="btn-action">Browse More <i class="bi bi-arrow-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

