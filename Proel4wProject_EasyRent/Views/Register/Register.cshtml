@model Proel4wProject_EasyRent.Models.Users
@{
    Layout = "~/Views/Shared/Register_Layout.cshtml";
    ViewData["Title"] = "Create Account";
}

<div class="mb-4">
    <h2 class="fw-bold h3 mb-1">Get Started</h2>
    <p class="text-muted">Create your account to start exploring our fleet.</p>
</div>

@* Changed action from SignUp to Register to match the Controller *@
<form asp-action="Register" class="needs-validation">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label small fw-semibold">First Name</label>
            <input asp-for="UserFirstName" class="form-control" placeholder="e.g. Ann" required />
            <span asp-validation-for="UserFirstName" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label small fw-semibold">Last Name</label>
            <input asp-for="UserLastName" class="form-control" placeholder="e.g. Navasca" required />
            <span asp-validation-for="UserLastName" class="text-danger small"></span>
        </div>
    </div>

    <div class="mt-3">
        <label class="form-label small fw-semibold">Email Address</label>
        <input asp-for="UserEmail" type="email" class="form-control" placeholder="name@email.com" required />
        <span asp-validation-for="UserEmail" class="text-danger small"></span>
    </div>

    <div class="mt-3">
        <label class="form-label small fw-semibold">Password</label>
        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    @* Added Confirm Password Field *@
    <div class="mt-3">
        <label class="form-label small fw-semibold">Confirm Password</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" required />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn btn-primary shadow-sm mt-4">
        Create Account <i class="bi bi-arrow-right ms-2"></i>
    </button>

    <div class="text-center mt-4">
        <p class="small text-muted">
            Already have an account?
            <a asp-controller="Account" asp-action="LoginView" class="text-primary text-decoration-none fw-bold ms-1">Sign In</a>
        </p>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}