@model Proel4wProject_EasyRent.Models.ViewModels.VehicleCreateViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add New Vehicle";
}

<div class="container-fluid">
    <div class="mb-3">
        <a asp-action="Index" class="text-decoration-none text-muted small d-inline-flex align-items-center">
            <i class="bi bi-arrow-left me-2"></i> Back to Fleet List
        </a>
    </div>

    <div class="management-card p-5 shadow-sm border-0 bg-white" style="border-radius: 16px;">
        <h2 class="fw-bold mb-0" style="font-family: Montserrat; color: #20515d;">Register Vehicle</h2>
        <p class="text-muted mb-4">Enter the details of the new vehicle for the rental fleet.</p>

        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            @* Image Upload Section *@
            <div class="mb-4">
                <label class="form-label fw-bold small text-muted text-uppercase">Vehicle Main Image (Cover)</label>
                <div class="border rounded-3 p-4 text-center bg-light mb-3" style="border-style: dashed !important; cursor: pointer;" onclick="document.getElementById('imageUpload').click();">
                    <div id="image-preview-area">
                        <i class="bi bi-cloud-arrow-up-fill text-muted" style="font-size: 2.5rem;"></i>
                        <p class="text-muted small mb-0 mt-2">Click to upload main vehicle image</p>
                    </div>
                    <img id="image-preview" src="#" alt="Preview" style="display: none; max-height: 200px; border-radius: 12px; object-fit: cover;" />
                </div>
                <input type="file" name="ImageFile" id="imageUpload" accept="image/*" class="d-none" onchange="previewImg(this, 'image-preview', 'image-preview-area')" />
                
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-0">Gallery Images (Minimum 4)</label>
                    <button type="button" id="add-gallery-btn" class="btn btn-sm btn-outline-teal" style="border-color: #20515d; color: #20515d;">
                        <i class="bi bi-plus-lg me-1"></i> Add More
                    </button>
                </div>
                <div class="row g-2" id="gallery-container">
                    @for (int i = 0; i < 4; i++)
                    {
                        var imgId = i + 2;
                        <div class="col-md-3 col-6 gallery-block">
                            <div class="border rounded-3 p-3 text-center bg-light h-100 d-flex flex-column justify-content-center align-items-center" style="border-style: dashed !important; cursor: pointer; min-height: 120px;" onclick="document.getElementById('imageUpload@(imgId)').click();">
                                <div id="img-area-@(imgId)"><i class="bi bi-plus-lg text-muted"></i><div class="small text-muted mt-1">Image @imgId</div></div>
                                <img id="img-prev-@(imgId)" src="#" alt="Preview" style="display: none; width: 100%; height: 80px; border-radius: 8px; object-fit: cover;" />
                            </div>
                            <input type="file" name="GalleryFiles" id="imageUpload@(imgId)" accept="image/*" class="d-none" onchange="previewImg(this, 'img-prev-@(imgId)', 'img-area-@(imgId)')" />
                        </div>
                    }
                </div>
            </div>

            @* Side-by-Side: Model Name and Price *@
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Vehicle.ModelName" class="form-label fw-bold small text-muted text-uppercase">Vehicle Model</label>
                    <input asp-for="Vehicle.ModelName" class="form-control" placeholder="e.g. Toyota Vios 2024" />
                    <span asp-validation-for="Vehicle.ModelName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Vehicle.StartingPrice" class="form-label fw-bold small text-muted text-uppercase">Starting Price (₱)</label>
                    <input asp-for="Vehicle.StartingPrice" class="form-control" placeholder="0.00" />
                    <span asp-validation-for="Vehicle.StartingPrice" class="text-danger small"></span>
                </div>
            </div>

            @* Vehicle Type, Status, Price Per *@
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label asp-for="Vehicle.VehicleType" class="form-label fw-bold small text-muted text-uppercase">Vehicle Type</label>
                    <select asp-for="Vehicle.VehicleType" class="form-select">
                        <option value="SUV">SUV</option>
                        <option value="Sedan">Sedan</option>
                        <option value="Van">Van</option>
                        <option value="Pickup">Pickup</option>
                        <option value="Hatchback">Hatchback</option>
                        <option value="Motorcycle">Motorcycle</option>
                    </select>
                    <span asp-validation-for="Vehicle.VehicleType" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Vehicle.Status" class="form-label fw-bold small text-muted text-uppercase">Status</label>
                    <select asp-for="Vehicle.Status" class="form-select">
                        <option value="Available">🟢 Available</option>
                        <option value="Rented">🔴 Rented</option>
                        <option value="Maintenance">🟡 Maintenance</option>
                    </select>
                    <span asp-validation-for="Vehicle.Status" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Vehicle.PricePer" class="form-label fw-bold small text-muted text-uppercase">Price Per</label>
                    <input asp-for="Vehicle.PricePer" class="form-control" placeholder="e.g. per 3 hours" />
                </div>
            </div>

            @* Fleet Count & Available *@
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Vehicle.FleetCount" class="form-label fw-bold small text-muted text-uppercase">Total Fleet Units</label>
                    <input asp-for="Vehicle.FleetCount" type="number" class="form-control" min="1" max="100" />
                    <span asp-validation-for="Vehicle.FleetCount" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Vehicle.AvailableFleet" class="form-label fw-bold small text-muted text-uppercase">Available Fleet Units</label>
                    <input asp-for="Vehicle.AvailableFleet" type="number" class="form-control" min="0" max="100" />
                    <span asp-validation-for="Vehicle.AvailableFleet" class="text-danger small"></span>
                </div>
            </div>

            @* Description *@
            <div class="mb-4">
                <label asp-for="Vehicle.Description" class="form-label fw-bold small text-muted text-uppercase">Description</label>
                <textarea asp-for="Vehicle.Description" class="form-control" rows="3" placeholder="Brief description of the vehicle experience..."></textarea>
                <span asp-validation-for="Vehicle.Description" class="text-danger small"></span>
            </div>

            <hr class="my-4 opacity-25">

            @* Specifications Section *@
            <h5 class="fw-bold mb-3" style="color: #20515d;">
                <i class="bi bi-list-columns me-2 text-primary"></i>Vehicle Specifications
            </h5>
            
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Vehicle.BodyType" class="form-label fw-bold small text-muted text-uppercase">Body Type</label>
                    <input asp-for="Vehicle.BodyType" class="form-control" placeholder="e.g. 7-Seater Midsize SUV" />
                    <span asp-validation-for="Vehicle.BodyType" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Vehicle.Engine" class="form-label fw-bold small text-muted text-uppercase">Engine</label>
                    <input asp-for="Vehicle.Engine" class="form-control" placeholder="e.g. 2.4L 4-cylinder Turbo Diesel" />
                    <span asp-validation-for="Vehicle.Engine" class="text-danger small"></span>
                </div>
            </div>
            
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Vehicle.Performance" class="form-label fw-bold small text-muted text-uppercase">Performance</label>
                    <input asp-for="Vehicle.Performance" class="form-control" placeholder="e.g. 181 hp and 430 Nm of torque" />
                    <span asp-validation-for="Vehicle.Performance" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Vehicle.Transmission" class="form-label fw-bold small text-muted text-uppercase">Transmission</label>
                    <input asp-for="Vehicle.Transmission" class="form-control" placeholder="e.g. 8-speed Automatic" />
                    <span asp-validation-for="Vehicle.Transmission" class="text-danger small"></span>
                </div>
            </div>
            
            <div class="mb-4">
                <label asp-for="Vehicle.Variants" class="form-label fw-bold small text-muted text-uppercase">Variants</label>
                <input asp-for="Vehicle.Variants" class="form-control" placeholder="e.g. Common trims include GLX, GLS..." />
                <span asp-validation-for="Vehicle.Variants" class="text-danger small"></span>
            </div>

            <hr class="my-4 opacity-25">

            @* Dynamic Benefits Section *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0" style="color: #20515d;">
                    <i class="bi bi-stars me-2 text-warning"></i>Vehicle Benefits
                </h5>
                <button type="button" id="add-benefit-btn" class="btn btn-sm btn-outline-teal" style="border-color: #20515d; color: #20515d;">
                    <i class="bi bi-plus-lg me-1"></i> Add Benefit
                </button>
            </div>

            <div id="benefit-container" class="mb-4">
                @for (int i = 0; i < Model.BenefitDescriptions.Count; i++)
                {
                    <div class="benefit-row input-group mb-2">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-check-circle-fill text-teal" style="color: #20515d;"></i>
                        </span>
                        <input name="BenefitDescriptions[@i]" class="form-control border-start-0" placeholder="e.g. Full Tank, GPS, Hybrid Engine" />
                    </div>
                }
            </div>

            <div class="mt-5 d-flex gap-2">
                <button type="submit" class="btn btn-teal px-5 py-2" style="background-color: #20515d; color: white; border: none; border-radius: 8px; font-weight: 600;">
                    <i class="bi bi-cloud-upload-fill me-2"></i> Create Vehicle
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Image preview mapping
        function previewImg(input, imgId, areaId) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById(imgId).src = e.target.result;
                    document.getElementById(imgId).style.display = 'inline-block';
                    document.getElementById(areaId).style.display = 'none';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Script to handle adding more benefit input fields dynamically
        document.getElementById('add-benefit-btn').addEventListener('click', function () {
            const container = document.getElementById('benefit-container');
            const index = container.getElementsByClassName('benefit-row').length;

            const div = document.createElement('div');
            div.className = 'benefit-row input-group mb-2';
            div.innerHTML = `
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-check-circle-fill" style="color: #20515d;"></i>
                </span>
                <input name="BenefitDescriptions[${index}]" class="form-control border-start-0" placeholder="Add a benefit..." />
            `;

            container.appendChild(div);
        });

        // Script to handle adding more gallery input blocks dynamically
        document.getElementById('add-gallery-btn').addEventListener('click', function () {
            const container = document.getElementById('gallery-container');
            const newIndex = container.children.length + 2; // Offset by 2 since image 1 is cover

            const div = document.createElement('div');
            div.className = 'col-md-3 col-6 gallery-block';
            div.innerHTML = `
                <div class="border rounded-3 p-3 text-center bg-light h-100 d-flex flex-column justify-content-center align-items-center" style="border-style: dashed !important; cursor: pointer; min-height: 120px;" onclick="document.getElementById('imageUpload${newIndex}').click();">
                    <div id="img-area-${newIndex}"><i class="bi bi-plus-lg text-muted"></i><div class="small text-muted mt-1">Image ${newIndex}</div></div>
                    <img id="img-prev-${newIndex}" src="#" alt="Preview" style="display: none; width: 100%; height: 80px; border-radius: 8px; object-fit: cover;" />
                </div>
                <input type="file" name="GalleryFiles" id="imageUpload${newIndex}" accept="image/*" class="d-none" onchange="previewImg(this, 'img-prev-${newIndex}', 'img-area-${newIndex}')" />
            `;

            container.appendChild(div);
        });
    </script>
}