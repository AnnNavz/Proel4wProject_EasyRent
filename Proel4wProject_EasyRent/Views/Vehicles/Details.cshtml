@model Proel4wProject_EasyRent.Models.Vehicle

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Vehicle Details";

    string badgeBg = Model.Status switch
    {
        "Rented" => "bg-danger",
        "Maintenance" => "bg-warning text-dark",
        _ => "bg-success"
    };
}

<div class="container-fluid">
    <div class="mb-3">
        <a asp-action="Index" class="text-decoration-none text-muted small">
            <i class="bi bi-arrow-left me-2"></i> Back to Fleet
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="management-card p-5 shadow-sm border-0 bg-white" style="border-radius: 16px;">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h2 class="fw-bold mb-0" style="font-family: Montserrat; color: #20515d;">@Model.ModelName</h2>
                        <p class="text-muted">Detailed specifications and included benefits.</p>
                    </div>
                    <span class="badge @badgeBg px-3 py-2 rounded-pill fw-bold">@Model.Status</span>
                </div>

                @* Vehicle Image *@
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="mb-4">
                        <img src="~/images/vehicles/@Model.ImagePath" alt="@Model.ModelName"
                             style="width: 100%; max-height: 350px; object-fit: cover; border-radius: 16px;" />
                    </div>
                }

                <div class="row mb-4">
                    <div class="col-md-3">
                        <label class="small text-muted text-uppercase fw-bold d-block">Starting Price</label>
                        <h4 class="fw-bold text-dark">₱ @Model.StartingPrice.ToString("N2")</h4>
                        <span class="small text-muted">@(Model.PricePer ?? "per hour")</span>
                    </div>
                    <div class="col-md-3">
                        <label class="small text-muted text-uppercase fw-bold d-block">Vehicle Type</label>
                        <p class="fw-semibold mb-0">@Model.VehicleType</p>
                    </div>
                    <div class="col-md-3">
                        <label class="small text-muted text-uppercase fw-bold d-block">Fleet Count</label>
                        <p class="fw-semibold mb-0">@Model.AvailableFleet / @Model.FleetCount units</p>
                    </div>
                    <div class="col-md-3">
                        <label class="small text-muted text-uppercase fw-bold d-block">Status</label>
                        <span class="badge @badgeBg rounded-pill px-3 py-1">@Model.Status</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mb-4">
                        <label class="small text-muted text-uppercase fw-bold d-block">Description</label>
                        <p class="text-dark">@Model.Description</p>
                    </div>
                }

                <h5 class="fw-bold mb-3" style="color: #20515d;">Standard Benefits</h5>
                <div class="row g-3">
                    @foreach (var benefit in Model.Benefits)
                    {
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 border rounded-3 bg-light bg-opacity-50">
                                <i class="bi bi-check-circle-fill me-3" style="color: #20515d;"></i>
                                <span class="fw-medium">@benefit.Description</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-5 d-flex gap-2 border-top pt-4">
                    <a asp-action="Edit" asp-route-id="@Model.VehicleId" class="btn btn-teal px-5" style="background-color: #20515d; color: white; border-radius: 8px;">
                        <i class="bi bi-pencil-square me-2"></i> Edit Details
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4" style="border-radius: 8px;">Close</a>
                </div>
            </div>
        </div>
    </div>
</div>