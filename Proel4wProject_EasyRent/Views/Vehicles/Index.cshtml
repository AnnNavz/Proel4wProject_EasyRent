@model IEnumerable<Proel4wProject_EasyRent.Models.Vehicle>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Vehicle Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 fw-bold" style="font-family: Montserrat; color: #20515d;">Vehicle Fleet</h1>
        <p class="text-muted">Manage your rental inventory and vehicle specifications.</p>
    </div>
    <a asp-action="Create" class="btn btn-teal px-4">
        <i class="bi bi-plus-circle-fill me-2"></i> Add New Vehicle
    </a>
</div>

<div class="management-card shadow-sm border-0 bg-white" style="border-radius: 16px; overflow: hidden;">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="bg-light">
                <tr class="text-muted small">
                    <th class="ps-4 py-3">IMAGE</th>
                    <th class="py-3">MODEL NAME</th>
                    <th class="py-3">TYPE</th>
                    <th class="py-3">STARTING PRICE</th>
                    <th class="py-3">STATUS</th>
                    <th class="py-3">FLEET</th>
                    <th class="py-3">KEY BENEFITS</th>
                    <th class="text-end pe-4 py-3">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    // Status badge styling
                    string badgeBg = item.Status switch
                    {
                        "Inactive" => "bg-danger",
                        _ => "bg-success"
                    };

                    <tr>
                        <td class="ps-4" style="width: 80px;">
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="~/images/vehicles/@item.ImagePath" alt="@item.ModelName"
                                     style="width: 60px; height: 45px; border-radius: 8px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center bg-light rounded-3" style="width: 60px; height: 45px;">
                                    <i class="bi bi-car-front text-muted"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="fw-bold text-dark fs-6">@item.ModelName</div>
                            <div class="small text-muted">ID: #VEH-@item.VehicleId</div>
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-light text-dark border fw-normal">@item.VehicleType</span>
                        </td>
                        <td>
                            <span class="fw-semibold text-dark">₱@item.StartingPrice.ToString("N2")</span>
                            <span class="small text-muted">/ @(item.PricePer ?? "hr")</span>
                        </td>
                        <td>
                            <span class="badge rounded-pill @badgeBg px-3 py-1">@item.Status</span>
                        </td>
                        <td>
                            <span class="fw-semibold">@item.AvailableFleet</span>
                            <span class="small text-muted">/ @item.FleetCount</span>
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var benefit in item.Benefits.Take(3))
                                {
                                    <span class="badge rounded-pill bg-light text-dark border fw-normal">
                                        <i class="bi bi-check2 text-teal me-1" style="color: #20515d;"></i>@benefit.Description
                                    </span>
                                }
                                @if (item.Benefits.Count > 3)
                                {
                                    <span class="badge rounded-pill bg-light text-muted border fw-normal">+@(item.Benefits.Count - 3) more</span>
                                }
                            </div>
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.VehicleId" class="btn btn-sm btn-light text-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.VehicleId" class="btn btn-sm btn-light text-info me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.VehicleId" class="btn btn-sm btn-light text-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>