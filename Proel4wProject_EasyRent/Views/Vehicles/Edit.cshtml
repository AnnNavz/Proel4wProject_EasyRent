@model Proel4wProject_EasyRent.Models.ViewModels.VehicleCreateViewModel

<h1>Edit Vehicle</h1>

<form asp-action="Edit">
    <input type="hidden" asp-for="Vehicle.VehicleId" />

    <div class="form-group">
        <label asp-for="Vehicle.ModelName"></label>
        <input asp-for="Vehicle.ModelName" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Vehicle.StartingPrice"></label>
        <input asp-for="Vehicle.StartingPrice" class="form-control" />
    </div>

    <h4>Benefits</h4>
    <div id="benefit-container">
        @for (int i = 0; i < Model.BenefitDescriptions.Count; i++)
        {
            <div class="benefit-row mb-2">
                <input name="BenefitDescriptions[@i]" value="@Model.BenefitDescriptions[i]" class="form-control" />
            </div>
        }
    </div>
    <button type="button" id="add-benefit-btn" class="btn btn-secondary btn-sm">+ Add Benefit</button>

    <div class="form-group mt-3">
        <input type="submit" value="Save Changes" class="btn btn-primary" />
    </div>
</form>


<div>
    <a asp-action="Index">Back to List</a>
</div>


@section Scripts {
    <script>
        document.getElementById('add-benefit-btn').addEventListener('click', function () {
            const container = document.getElementById('benefit-container');
            const index = container.getElementsByClassName('benefit-row').length;
            const div = document.createElement('div');
            div.className = 'benefit-row mb-2';
            div.innerHTML = `<input name="BenefitDescriptions[${index}]" class="form-control" placeholder="Add a benefit..." />`;
            container.appendChild(div);
        });
    </script>
}