@model Proel4wProject_EasyRent.Models.Vehicle

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Remove Vehicle";
}

<div class="container-fluid text-center">
    <div class="row justify-content-center mt-5">
        <div class="col-lg-6">
            <div class="management-card p-5 shadow-sm border-0 bg-white" style="border-radius: 20px;">
                <div class="mb-4">
                    <div class="bg-danger bg-opacity-10 text-danger d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-exclamation-triangle-fill h2 mb-0"></i>
                    </div>
                    <h2 class="fw-bold" style="color: #20515d;">Confirm Deletion</h2>
                    <p class="text-muted">Are you sure you want to remove <strong>@Model.ModelName</strong> from the fleet? This action cannot be undone.</p>
                </div>

                <div class="bg-light p-4 rounded-3 mb-4 text-start">
                    <div class="row">
                        <div class="col-6">
                            <span class="small text-muted text-uppercase fw-bold">Vehicle Model</span>
                            <p class="mb-0 fw-bold">@Model.ModelName</p>
                        </div>
                        <div class="col-6 text-end">
                            <span class="small text-muted text-uppercase fw-bold">Daily Rate</span>
                            <p class="mb-0 fw-bold text-danger">₱ @Model.StartingPrice.ToString("N2")</p>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="VehicleId" />
                    <div class="d-flex flex-column gap-2">
                        <button type="submit" class="btn btn-danger py-3 fw-bold" style="border-radius: 12px;">
                            <i class="bi bi-trash3-fill me-2"></i> Confirm and Delete
                        </button>
                        <a asp-action="Index" class="btn btn-link text-decoration-none text-muted fw-semibold py-2">
                            No, keep this vehicle
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>