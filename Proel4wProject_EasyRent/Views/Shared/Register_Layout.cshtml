<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EasyRent</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-blue: #0d6efd;
            --dark-navy: #1e293b;
            --soft-bg: #f8fafc;
        }

        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--soft-bg);
            color: var(--dark-navy);
        }

        .split-container {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* Left Side: Dynamic Image Section */
        .image-section {
            flex: 1.2;
            background: linear-gradient(rgba(15, 23, 42, 0.5), rgba(15, 23, 42, 0.8)), url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=1920');
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 80px;
            color: white;
            transition: all 0.5s ease;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 30px;
            border-radius: 20px;
            max-width: 500px;
        }

        /* Right Side: Clean Form Section */
        .form-section {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            padding: 40px;
            box-shadow: -10px 0 30px rgba(0,0,0,0.05);
            z-index: 10;
        }

        .form-card {
            width: 100%;
            max-width: 420px;
        }

        .brand-logo {
            font-weight: 800;
            font-size: 1.75rem;
            color: var(--primary-blue);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            letter-spacing: -0.5px;
        }

        .form-label {
            color: #64748b;
            margin-bottom: 0.5rem;
        }

        .form-control {
            border-radius: 10px;
            padding: 12px 16px;
            border: 1px solid #e2e8f0;
            background-color: #ffffff;
            transition: all 0.2s ease;
        }

            .form-control:focus {
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
                border-color: var(--primary-blue);
            }

        .btn-primary {
            padding: 14px;
            border-radius: 10px;
            font-weight: 600;
            width: 100%;
            margin-top: 1.5rem;
            background-color: var(--primary-blue);
            border: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .btn-primary:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(13, 110, 253, 0.25);
            }

    </style>
</head>
<body>
    <div class="split-container">
        <div class="image-section">
            <div class="glass-card">
                <h1 class="display-5 fw-bold mb-3">Premium Travel, <br>Simplified.</h1>
                <p class="lead opacity-75">Join thousands of travelers who trust EasyRent for their daily journeys and weekend getaways.</p>
                <div class="d-flex gap-3 mt-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-info me-2"></i>
                        <span class="small">Verified Fleet</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-info me-2"></i>
                        <span class="small">24/7 Support</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-card">
                <div class="brand-logo">
                    <i class="bi bi-car-front-fill me-2"></i> EasyRent
                </div>
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>